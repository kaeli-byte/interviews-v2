# Backend (FastAPI)
GEMINI_API_KEY=your-gemini-api-key
JWT_SECRET_KEY=your-secret-key-here
# Supabase connection (use connection pooler for better performance)
DIRECT_URL=postgresql://user:password@host:6543/dbname  # Direct connection (for migrations)
SUPABASE_DB_URL=postgresql://user:password@host:5432/dbname  # Connection pooler

# Frontend (Next.js) - copy to frontend/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key